# =====================================================
# CodeLens — .gitignore
# Covers: Java + Python + Node + .env + OS + IDE + Docker
# =====================================================

# -----------------------------------------------------
# Environment files (NEVER commit secrets)
# -----------------------------------------------------
.env
.env.*
!.env.example
.env.local
.env.development
.env.production
.env.test

# -----------------------------------------------------
# General Build & Output Artifacts
# -----------------------------------------------------
build/
dist/
out/
target/
bin/
*.class
*.jar
*.war
*.ear
*.vsix
*.tsbuildinfo

# The GitHub Action must commit its self-contained runtime bundle.
!github-action/dist/
!github-action/dist/index.js
!github-action/dist/licenses.txt
!github-action/dist/package.json

# -----------------------------------------------------
# Dependency Directories
# -----------------------------------------------------
node_modules/
.pnpm-store/
bun.lockb

# -----------------------------------------------------
# Java & IDEs (IntelliJ, Eclipse, VS Code)
# -----------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
.classpath
.project
.cproject
.factorypath
.buildpath
.springBeans
.sts4-cache/
.vscode/
spring-boot-devtools.properties

# -----------------------------------------------------
# Python & ML Worker
# -----------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
.python-version
develop-eggs/
downloads/
eggs/
.eggs/
parts/
sdist/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pylint.d/
.ipynb_checkpoints/

# ML / Data / Model Artifacts
*.pt
*.pth
*.pkl
*.h5
*.onnx
*.safetensors
*.bin
*.npy
*.npz
*.parquet
.huggingface/
hf_cache/
mlruns/
wandb/

# Training Data (Keep directories via .gitkeep, ignore data contents)
apps/ml-worker/training/data/raw/*
apps/ml-worker/training/data/filtered/*
apps/ml-worker/training/data/labeled/*
!apps/ml-worker/training/data/raw/.gitkeep
!apps/ml-worker/training/data/filtered/.gitkeep
!apps/ml-worker/training/data/labeled/.gitkeep
apps/ml-worker/training/data/train.json
apps/ml-worker/training/data/val.json
# NOTE: test.json is intentionally NOT ignored — committed but never opened until final eval

# -----------------------------------------------------
# Web / Next.js
# -----------------------------------------------------
.next/
next-env.d.ts
.vercel

# -----------------------------------------------------
# Docker & System Logs
# -----------------------------------------------------
postgres_data/
redis_data/
*.log
logs/
spring.log
fastapi.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------
# OS-specific Files & Temp/Backups
# -----------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk
*~
.fuse_hidden*
.Trash-*
*.swp
*.swo
*.bak
*.tmp
*.orig
.local/
