# =====================================================
# CodeLens — .gitignore
# Covers: Java + Python + Node + .env + OS + IDE + Docker
# =====================================================

# -----------------------------------------------------
# Environment files (NEVER commit secrets)
# -----------------------------------------------------
.env
.env.*
!.env.example
.env.local
.env.development
.env.production
.env.test

# -----------------------------------------------------
# Java / Maven / Spring Boot
# -----------------------------------------------------
*.class
*.jar
*.war
*.ear

# Maven build output
target/
build/
out/
*.classpath
*.project
*.settings/

# Gradle (just in case)
.gradle/
build/

# Spring Boot DevTools
spring-boot-devtools.properties

# IDE — IntelliJ
.idea/
*.iml
*.iws
*.ipr

# IDE — Eclipse
.classpath
.project
.cproject
.factorypath
.buildpath
.springBeans
.sts4-cache/
bin/

# IDE — VS Code
.vscode/

# OS
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# Logs
*.log
logs/
spring.log
fastapi.log

# -----------------------------------------------------
# Python (ml-worker)
# -----------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
.venv/
env/
ENV/
.python-version

# Distribution / packaging
develop-eggs/
downloads/
eggs/
.eggs/
parts/
sdist/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
build/
dist/

# Unit test / coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Jupyter
.ipynb_checkpoints

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json

# Linters
.ruff_cache/
.pylint.d/

# ML / data / model artifacts
*.pt
*.pth
*.pkl
*.h5
*.onnx
*.safetensors
*.bin
*.npy
*.npz
*.parquet

# HuggingFace cache
.huggingface/
hf_cache/

# Large data
data/raw/
data/filtered/
data/labeled/
apps/ml-worker/training/data/raw/*
apps/ml-worker/training/data/filtered/*
apps/ml-worker/training/data/labeled/*
!apps/ml-worker/training/data/raw/.gitkeep
!apps/ml-worker/training/data/filtered/.gitkeep
!apps/ml-worker/training/data/labeled/.gitkeep
apps/ml-worker/training/data/train.json
apps/ml-worker/training/data/val.json
# NOTE: test.json is intentionally NOT ignored — committed but never opened until final eval
#
# Keep the data/ subdirectories themselves tracked (so .gitkeep placeholders
# inside them can be committed), but ignore the actual data files.

# MLflow / Weights & Biases
mlruns/
wandb/

# -----------------------------------------------------
# Node / Next.js / VS Code Extension
# -----------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Next.js
.next/
out/
next-env.d.ts
.vercel

# Build outputs
dist/
build/
*.tsbuildinfo

# Coverage
coverage/
.nyc_output/

# Cache
.cache/
.parcel-cache/
.eslintcache

# pnpm
.pnpm-store/

# Bun
bun.lockb

# -----------------------------------------------------
# Docker
# -----------------------------------------------------
# Allow committed Dockerfiles; ignore runtime volumes
postgres_data/
redis_data/
hf_cache/

# -----------------------------------------------------
# OS-specific
# -----------------------------------------------------
# Windows
desktop.ini
ehthumbs.db
Thumbs.db
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.fuse_hidden*
.Trash-*

# -----------------------------------------------------
# Misc
# -----------------------------------------------------
*.swp
*.swo
*~
*.bak
*.tmp
*.orig

# Local config
.local/
