# =====================================================
# CodeLens — .env.example
# Copy to .env and fill in real values.
# NEVER commit .env. It is .gitignored.
# =====================================================

# -----------------------------------------------------
# GitHub OAuth App
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:8080/api/auth/callback
# -----------------------------------------------------
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# -----------------------------------------------------
# JWT signing key (access tokens + refresh tokens)
# Generate: openssl rand -base64 64
# -----------------------------------------------------
JWT_SECRET=your_64_char_base64_secret

# -----------------------------------------------------
# AES encryption key for DB fields
# Encrypts: GitHub OAuth tokens, webhook secrets
# Generate: openssl rand -base64 32
# Must be exactly 32 bytes when decoded (base64-decoded)
# -----------------------------------------------------
ENCRYPTION_KEY=your_32_char_base64_key

# -----------------------------------------------------
# HuggingFace (for private model access + pushing fine-tuned model)
# Get token: https://huggingface.co/settings/tokens
# -----------------------------------------------------
HF_TOKEN=hf_xxxxxxxxxxxxx

# ML model name on HuggingFace Hub (private repo after fine-tuning)
ML_MODEL_NAME=tanmay-alpha/codelens-codebert

# -----------------------------------------------------
# ML Worker (FastAPI) — internal secret
# Shared between Spring Boot and FastAPI via header
# Spring Boot sends it; FastAPI validates it
# Generate: openssl rand -hex 32
# -----------------------------------------------------
ML_WORKER_SECRET=your_random_32_char_secret

# FastAPI URL (used by Spring Boot WebClient)
ML_WORKER_URL=http://localhost:8000

# -----------------------------------------------------
# Next.js (apps/web)
# -----------------------------------------------------
# Used by NextAuth for CSRF / session token signing
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret

# Public URL of the Spring Boot API (browser-visible)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Public URL of the Next.js app itself
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------
# Database (PostgreSQL)
# Used by Spring Boot. For local non-Docker dev only.
# In Docker Compose, overridden by service-level env vars.
# -----------------------------------------------------
DATABASE_URL=postgresql://codelens:codelens_local@localhost:5432/codelens

# Direct JDBC vars (used by Spring Boot application.yml)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/codelens
SPRING_DATASOURCE_USERNAME=codelens
SPRING_DATASOURCE_PASSWORD=codelens_local

# Redis (Spring Boot)
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379

# -----------------------------------------------------
# Spring profile (dev | prod)
# -----------------------------------------------------
SPRING_PROFILES_ACTIVE=dev

# -----------------------------------------------------
# Local infrastructure defaults (used by docker-compose.yml)
# These match docker-compose.yml's hardcoded values.
# -----------------------------------------------------
POSTGRES_DB=codelens
POSTGRES_USER=codelens
POSTGRES_PASSWORD=codelens_local
