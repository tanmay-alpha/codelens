{
  "name": "codelens-action",
  "version": "1.0.0",
  "description": "GitHub Action: semantic code review via the CodeLens API",
  "main": "index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node index.js",
    "build": "ncc build index.js -o dist --minify --license licenses.txt",
    "test": "node --test test/smoke.test.cjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1"
  },
  "keywords": [
    "code-review",
    "static-analysis",
    "anti-patterns",
    "codelens"
  ],
  "license": "MIT",
  "devDependencies": {
    "@vercel/ncc": "^0.44.0"
  }
}
